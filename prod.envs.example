# 本番の環境変数。実物は prod.envs (gitignore 済み) として置く。一覧の解説は docs/MIGRATION.md §1.3
RAILS_ENV=production
SECRET_KEY_BASE=CHANGE_ME

# MySQL (コンテナ外)。ホスト上の MySQL なら DB_HOST=host.docker.internal 等
DB_HOST=CHANGE_ME
DB_PORT=3306
DB_USERNAME=uprun
DB_PASSWORD=CHANGE_ME
DB_NAME=uprun_production

# Google OAuth (Cloud Console)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# 任意 (既定値あり)
# MAX_UPLOAD_MB=50
# TRASH_RETENTION_DAYS=30
